# ~/.bash_local_nogpu: non-CUDA machine-specific shell customizations for this computer.

# ---- Local toolchains ----
if [ -x "${HOME}/.linuxbrew/bin/brew" ]; then
    eval "$("${HOME}/.linuxbrew/bin/brew" shellenv bash)"
elif [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
fi

append_unique_path_if_exists() {
    local var_name="$1"
    local path_value="$2"
    local current_value="${!var_name-}"

    [ -z "$path_value" ] && return 0
    [ -d "$path_value" ] || return 0

    path_value="${path_value%/}"

    case ":${current_value}:" in
        *":${path_value}:"*)
            ;;
        *)
            if [ -n "${current_value}" ]; then
                printf -v "$var_name" '%s:%s' "$current_value" "$path_value"
            else
                printf -v "$var_name" '%s' "$path_value"
            fi
            export "$var_name"
            ;;
    esac
}

if [ -f "${HOME}/miniforge3/etc/profile.d/conda.sh" ]; then
    . "${HOME}/miniforge3/etc/profile.d/conda.sh"
fi
